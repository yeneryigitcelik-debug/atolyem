# Database (Postgres)
# For local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atolyem?schema=public"
# Direct connection for migrations (no pooler)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/atolyem"

# For production (Supabase)
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="<YOUR_SECRET_HERE>"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare Images
CLOUDFLARE_ACCOUNT_ID="<YOUR_ACCOUNT_ID>"
CLOUDFLARE_IMAGES_API_TOKEN="<YOUR_API_TOKEN>"
CLOUDFLARE_ACCOUNT_HASH="<YOUR_ACCOUNT_HASH>"
NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_HASH="<YOUR_ACCOUNT_HASH>"
CLOUDFLARE_IMAGES_VARIANT="public"

# Base URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Payment Gateways (Optional)
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# AI Keys (Optional)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
