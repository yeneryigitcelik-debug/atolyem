// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =========================
 * APP MODELLERİN (MEVCUT)
 * =========================
 */

model User {
  id        String   @id @default(cuid()) // PK
  email     String   @unique // Benzersiz e-posta
  name      String? // Görünen ad
  hashedPw  String // Bcrypt şifre hash (Credentials)
  role      UserRole @default(CUSTOMER) // Rol
  isPremium Boolean  @default(false) // Premium abonelik durumu
  seller    Seller? // Satıcı (opsiyonel)
  orders    Order[] // Siparişleri
  addresses Address[] // Kullanıcı adresleri
  subscriptions Subscription[] // Premium abonelikler
  createdAt DateTime @default(now()) // Oluşturulma
  updatedAt DateTime @updatedAt // Güncellenme

  // NextAuth için ek alan/ilişkiler:
  emailVerified DateTime? // E-posta doğrulama tarihi
  image         String? // Avatar (opsiyonel)
  bannerImage   String? // Profil arka plan görseli (opsiyonel)
  accounts      Account[] // NextAuth hesapları
  sessions      Session[] // NextAuth oturumları
  
  // Mesajlaşma
  participants Participant[] // Konuşmalara katılım
  
  // Pazaryeri özellikleri
  reviews       Review[] // Ürün yorumları
  sellerReviews SellerReview[] @relation("SellerReviews") // Satıcı yorumları
  favoriteSellers FavoriteSeller[] @relation("FavoriteSellers") // Favori satıcılar
  favoriteProducts FavoriteProduct[] @relation("FavoriteProducts") // Favori ürünler
  feedbacks     Feedback[] // Geri bildirimler
}

model Seller {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  displayName   String
  commissionBps Int       @default(1500)
  products      Product[]
  payouts       Payout[]
  payoutLedger SellerPayoutLedger[] // Komisyon defteri
  metrics       SellerMetrics[] // Performans metrikleri
  feedbacks     Feedback[] // Geri bildirimler
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Profil bilgileri
  bio           String?   // Mağaza açıklaması
  bannerImage   String?   // Mağaza banner görseli
  location      String?   // Konum (şehir/ülke)
  website       String?   // Web sitesi
  instagram     String?   // Instagram kullanıcı adı
  facebook      String?   // Facebook sayfası
  twitter       String?   // Twitter kullanıcı adı
  
  // Mağaza ayarları
  returnPolicy  String?   // İade politikası
  shippingInfo  String?   // Kargo bilgileri
  shopPolicies  String?   // Mağaza kuralları
  
  // İstatistikler (cache için)
  totalSales    Int       @default(0) // Toplam satış sayısı
  totalRevenue  Int       @default(0) // Toplam gelir (cents)
  
  // Pazaryeri özellikleri
  reviews       SellerReview[] // Satıcı yorumları
  favorites     FavoriteSeller[] // Favorilere ekleyenler
  coupons       Coupon[] // Kuponlar
}

model Category {
  id       String     @id @default(cuid())
  name     String     @unique
  slug     String     @unique
  parentId String?
  children Category[] @relation("CategoryToCategory")
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  products Product[]
}

model Product {
  id          String         @id @default(cuid())
  sellerId    String
  seller      Seller         @relation(fields: [sellerId], references: [id])
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  title       String
  slug        String         @unique
  description String?
  images      ProductImage[]
  variants    Variant[]
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  conversations Conversation[] // Bu ürünle ilgili konuşmalar
  reviews     Review[] // Ürün yorumları
  favorites   FavoriteProduct[] // Favorilere ekleyenler
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  url        String
  cfImageId  String? // Cloudflare Images ID (direct upload için)
  alt        String?
  sort       Int     @default(0)
  product    Product @relation(fields: [productId], references: [id])
}

model Variant {
  id         String      @id @default(cuid())
  productId  String
  sku        String      @unique
  priceCents Int
  stock      Int         @default(0)
  attributes Json?
  product    Product     @relation(fields: [productId], references: [id])
  // Back-relation: OrderItem.variant
  orderItems OrderItem[] // <- isim konvansiyonu (daha önce migrate olduysa buna uyarlandı)
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  status     OrderStatus @default(CART)
  items      OrderItem[]
  totalCents Int         @default(0)
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id])
  conversations Conversation[] // Bu siparişle ilgili konuşmalar
  reviews    Review[] // Ürün yorumları
  sellerReviews SellerReview[] @relation("SellerReviewOrder") // Satıcı yorumları
  couponCode String? // Uygulanan kupon kodu
  discountCents Int @default(0) // İndirim tutarı (cents)
  addressId  String? // Sipariş adresi
  address    Address?   @relation(fields: [addressId], references: [id])
  shipments  Shipment[] // Kargo kayıtları
  payments   Payment[]  // Ödeme kayıtları
  feedbacks  Feedback[] @relation("FeedbackOrder") // Geri bildirimler
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  variantId  String
  qty        Int     @default(1)
  priceCents Int
  order      Order   @relation(fields: [orderId], references: [id])
  variant    Variant @relation(fields: [variantId], references: [id])
}

model Payout {
  id          String   @id @default(cuid())
  sellerId    String
  amountCents Int
  note        String?
  createdAt   DateTime @default(now())
  seller      Seller   @relation(fields: [sellerId], references: [id])
}

enum UserRole {
  ADMIN
  SELLER
  CUSTOMER
}

enum OrderStatus {
  CART
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELED
}

enum ShipmentStatus {
  CREATED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentGateway {
  IYZICO
  PAYTR
}

/**
 * =========================
 * MESAJLAŞMA MODELLERİ
 * =========================
 */

model Conversation {
  id           String         @id @default(cuid())
  productId    String?        // Bir ürün konuşmasıysa
  orderId      String?        // Sipariş sonrası konuşma ise
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  participants Participant[]
  messages     Message[]
  product      Product?       @relation(fields: [productId], references: [id])
  order        Order?         @relation(fields: [orderId], references: [id])

  @@index([productId])
  @@index([orderId])
}

model Participant {
  id             String        @id @default(cuid())
  conversationId String
  userId         String
  role           ParticipantRole // "BUYER" | "SELLER"
  joinedAt       DateTime      @default(now())
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@unique([conversationId, userId]) // Aynı kişi aynı konuşmada bir kez
}

model Message {
  id             String        @id @default(cuid())
  conversationId  String
  senderId        String
  body            String?       // Metin varsa
  imageId         String?       // Cloudflare Images imageId
  createdAt       DateTime      @default(now())
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum ParticipantRole {
  BUYER
  SELLER
}

/**
 * =========================
 * PAZARYERİ ÖZELLİKLERİ
 * =========================
 */

model Review {
  id        String   @id @default(cuid())
  productId String
  orderId   String?  // Hangi siparişten sonra yapıldı
  userId    String   // Yorum yapan kullanıcı
  rating    Int      // 1-5 arası puan
  comment   String?  // Yorum metni
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  order     Order?   @relation(fields: [orderId], references: [id])

  @@unique([productId, userId, orderId]) // Aynı sipariş için tek yorum
  @@index([productId])
  @@index([userId])
}

model SellerReview {
  id        String   @id @default(cuid())
  sellerId  String
  orderId   String?  // Hangi siparişten sonra yapıldı
  userId    String   // Yorum yapan kullanıcı
  rating    Int      // 1-5 arası puan
  comment   String?  // Yorum metni
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  user      User     @relation("SellerReviews", fields: [userId], references: [id])
  order     Order?   @relation("SellerReviewOrder", fields: [orderId], references: [id])

  @@unique([sellerId, userId, orderId]) // Aynı sipariş için tek yorum
  @@index([sellerId])
  @@index([userId])
}

model FavoriteSeller {
  id       String   @id @default(cuid())
  userId   String
  sellerId String
  createdAt DateTime @default(now())
  user     User     @relation("FavoriteSellers", fields: [userId], references: [id], onDelete: Cascade)
  seller   Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([userId, sellerId]) // Aynı satıcıyı bir kez favorilere ekle
  @@index([userId])
  @@index([sellerId])
}

model FavoriteProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation("FavoriteProducts", fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // Aynı ürünü bir kez favorilere ekle
  @@index([userId])
  @@index([productId])
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique // Kupon kodu
  sellerId    String?   // Belirli bir satıcı için ise
  discountType DiscountType // PERCENTAGE veya FIXED
  discountValue Int     // Yüzde veya sabit tutar (cents)
  minPurchase Int?      // Minimum alışveriş tutarı (cents)
  maxDiscount Int?      // Maksimum indirim (cents) - sadece yüzde için
  validFrom   DateTime
  validUntil  DateTime
  usageLimit  Int?      // Toplam kullanım limiti
  usedCount   Int       @default(0) // Kullanım sayısı
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  seller      Seller?   @relation(fields: [sellerId], references: [id])

  @@index([code])
  @@index([sellerId])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

/**
 * =========================
 * NEXTAUTH MODELLERİ (YENİ)
 * =========================
 */

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String? @db.Text
  access_token  String? @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String? @db.Text
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/**
 * =========================
 * ADRES & KARGO & ÖDEME MODELLERİ
 * =========================
 */

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String   // "Ev", "İş", "Diğer" gibi
  city       String   // Şehir
  district   String   // İlçe
  addressLine String  // Detaylı adres
  phone      String?  // Telefon
  isDefault  Boolean  @default(false) // Varsayılan adres
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]  // Bu adrese gönderilen siparişler

  @@index([userId])
}

model Shipment {
  id           String         @id @default(cuid())
  orderId      String
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier      String         // "PTT", "Yurtiçi", "Aras", "MNG" vb.
  trackingCode String?        // Takip numarası
  status       ShipmentStatus @default(CREATED)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([orderId])
  @@index([trackingCode])
}

model Payment {
  id         String         @id @default(cuid())
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gateway    PaymentGateway // İyzico veya PayTR
  txnId      String?        @unique // Gateway transaction ID
  status     PaymentStatus  @default(PENDING)
  amountCents Int           // Ödeme tutarı (cents)
  rawPayload  Json?          // Gateway'den gelen ham yanıt (webhook için)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([orderId])
  @@index([txnId])
  @@unique([orderId, txnId]) // Aynı sipariş için aynı txnId tekrar edemez (idempotency)
}

model SellerPayoutLedger {
  id        String   @id @default(cuid())
  sellerId  String
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderId   String?  // Hangi siparişten kaynaklandı (opsiyonel, manuel girişler için)
  type      String   // "debit" veya "credit"
  amountCents Int    // Tutar (cents)
  note      String?  // Açıklama
  createdAt DateTime @default(now())

  @@index([sellerId])
  @@index([orderId])
}

/**
 * =========================
 * PREMIUM ABONELİK MODELLERİ
 * =========================
 */

model Subscription {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan @default(BASIC)
  status        SubscriptionStatus @default(ACTIVE)
  amountCents   Int             // Aylık ücret (cents)
  startedAt     DateTime        @default(now())
  expiresAt     DateTime?       // Otomatik yenileme varsa null
  canceledAt    DateTime?       // İptal tarihi
  paymentGateway PaymentGateway // Ödeme sağlayıcısı
  gatewaySubscriptionId String? // Gateway'deki subscription ID
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model SellerMetrics {
  id              String   @id @default(cuid())
  sellerId        String
  seller          Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  month           Int      // 1-12
  year            Int      // Yıl
  totalSales      Int      @default(0) // Toplam satış sayısı
  totalRevenueCents Int    @default(0) // Toplam gelir (cents)
  completedOrders Int      @default(0) // Tamamlanan sipariş sayısı
  canceledOrders  Int      @default(0) // İptal edilen sipariş sayısı
  averageOrderValueCents Int @default(0) // Ortalama sipariş değeri (cents)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sellerId, month, year])
  @@index([sellerId])
  @@index([year, month])
}

enum SubscriptionPlan {
  BASIC      // Ücretsiz plan
  PREMIUM    // Premium plan
  ENTERPRISE // Kurumsal plan
}

enum SubscriptionStatus {
  ACTIVE     // Aktif
  CANCELED   // İptal edilmiş
  EXPIRED    // Süresi dolmuş
  PENDING    // Ödeme bekliyor
}

/**
 * =========================
 * GERİ BİLDİRİM MODELLERİ
 * =========================
 */

model Feedback {
  id          String         @id @default(cuid())
  sellerId    String
  seller      Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  orderId     String?        // Hangi sipariş için geri bildirim
  order       Order?         @relation("FeedbackOrder", fields: [orderId], references: [id])
  rating      Int            // 1-5 arası puan
  comment     String?       // Geri bildirim metni
  category    FeedbackCategory // Geri bildirim kategorisi
  status      FeedbackStatus @default(PENDING) // Admin onay durumu
  adminNote   String?       // Admin notu
  reviewedBy  String?       // Onaylayan admin ID
  reviewedAt  DateTime?     // Onay tarihi
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([sellerId])
  @@index([userId])
  @@index([status])
  @@index([orderId])
}

enum FeedbackCategory {
  PRODUCT_QUALITY    // Ürün kalitesi
  SHIPPING          // Kargo
  COMMUNICATION     // İletişim
  PRICING           // Fiyatlandırma
  GENERAL           // Genel
}

enum FeedbackStatus {
  PENDING    // Beklemede
  APPROVED   // Onaylandı
  REJECTED   // Reddedildi
}
